{
  "id": "video-youtube-classic",
  "name": "YouTube Classic Video Skin",
  "version": "1.0.0",
  "targets": ["video"],
  "description": "Familiar video player skin inspired by YouTube's classic design",
  "tokens": {
    "--video-bg": "#000000",
    "--video-controls-bg": "linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%)",
    "--video-controls-color": "#ffffff",
    "--video-accent-color": "#ff0000",
    "--video-timeline-bg": "rgba(255, 255, 255, 0.25)",
    "--video-timeline-progress": "#ff0000",
    "--video-timeline-buffered": "rgba(255, 255, 255, 0.5)",
    "--video-timeline-hover": "rgba(255, 0, 0, 0.3)",
    "--video-control-hover": "rgba(255, 255, 255, 0.15)",
    "--video-border-radius": "0px",
    "--video-control-size": "36px",
    "--video-transition": "all 0.15s linear"
  },
  "classes": {
    "container": "relative w-full overflow-hidden bg-black",
    "video": "w-full h-full object-contain",
    "controlsBar": "absolute bottom-0 left-0 right-0 flex flex-col gap-1 px-3 pb-2 bg-gradient-to-t from-black/80 to-transparent pt-16",
    "timelineContainer": "w-full flex flex-col gap-1",
    "playButton": "flex items-center justify-center w-9 h-9 hover:bg-white/15 transition-colors cursor-pointer rounded",
    "timeline": "w-full h-1 bg-white/25 cursor-pointer relative group",
    "timelineProgress": "absolute inset-y-0 left-0 bg-red-600 pointer-events-none",
    "timelineBuffered": "absolute inset-y-0 left-0 bg-white/50 pointer-events-none",
    "timelineThumb": "absolute top-1/2 -translate-y-1/2 w-3 h-3 rounded-full bg-red-600 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none",
    "controlsRow": "flex items-center gap-2",
    "timeText": "text-sm text-white font-medium",
    "volumeControl": "flex items-center gap-1.5",
    "volumeSlider": "w-16 h-1 bg-white/25 rounded-full cursor-pointer relative",
    "fullscreenButton": "flex items-center justify-center w-9 h-9 hover:bg-white/15 transition-colors cursor-pointer rounded ml-auto",
    "settingsButton": "flex items-center justify-center w-9 h-9 hover:bg-white/15 transition-colors cursor-pointer rounded",
    "qualityButton": "flex items-center gap-1 px-2 py-1 text-xs font-medium hover:bg-white/15 rounded cursor-pointer",
    "loadingSpinner": "absolute inset-0 flex items-center justify-center bg-black/50",
    "playOverlay": "absolute inset-0 flex items-center justify-center cursor-pointer",
    "playOverlayButton": "w-16 h-16 flex items-center justify-center bg-black/60 hover:bg-red-600 transition-colors duration-200 rounded-sm"
  },
